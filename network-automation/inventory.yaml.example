# inventory.yaml.example
# ─────────────────────────────────────────────────────────
# Example device inventory for network_backup.py
# Copy this file to inventory.yaml and update with your
# real device details. Never commit inventory.yaml to Git
# as it may contain credentials.
# ─────────────────────────────────────────────────────────

devices:

  # ── Cisco IOS Routers ──────────────────────────────────
  - host: 192.168.1.1
    device_type: cisco_ios
    hostname: CORE-RTR-01
    username: admin
    password: your_password_here   # use vault or env vars in production

  - host: 192.168.1.2
    device_type: cisco_ios
    hostname: DIST-SW-01
    username: admin
    password: your_password_here

  # ── Cisco NX-OS (Data Centre) ──────────────────────────
  - host: 192.168.2.1
    device_type: cisco_nxos
    hostname: DC-LEAF-01
    username: admin
    password: your_password_here

  # ── Juniper JunOS ──────────────────────────────────────
  - host: 192.168.1.3
    device_type: juniper_junos
    hostname: EDGE-FW-01
    username: admin
    password: your_password_here

# ─────────────────────────────────────────────────────────
# Supported device_type values:
#   cisco_ios       — Cisco IOS / IOS-XE routers & switches
#   cisco_nxos      — Cisco Nexus data centre switches
#   juniper_junos   — Juniper MX, SRX, EX series
#
# Security note:
#   Do not store plaintext passwords in production.
#   Use environment variables or a secrets manager instead:
#
#   password: !ENV DEVICE_PASSWORD
# ─────────────────────────────────────────────────────────
